{
  "Version": "1.0",
  "Seccomp": {
    "WhiteList": [
      "access",
      "arch_prctl",
      "brk",
      "clock_gettime",
      "clock_nanosleep",
      "close",
      "exit_group",
      "faccessat",
      "fcntl",
      "fstat",
      "futex",
      "flock",
      "getpid",
      "gettid",
      "getrandom",
      "ioctl",
      "lseek",
      "madvise",
      "mmap",
      "mprotect",
      "munmap",
      "newfstatat",
      "pipe2",
      "pread64",
      "prctl",
      "prlimit64",
      "read",
      "readlink",
      "readlinkat",
      "readv",
      "rseq",
      "rt_sigaction",
      "rt_sigprocmask",
      "seccomp",
      "set_robust_list",
      "set_tid_address",
      "sigaltstack",
      "write",
      "writev"
    ],
    "RestrictExecveToProgramPath": true,
    "AllowIO": true
  }
}
